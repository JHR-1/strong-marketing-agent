# ----------------------------------------------------------------------
# Strong Recruitment Group — Marketing Agent
# Environment variables
# ----------------------------------------------------------------------

# Server
PORT=3000
NODE_ENV=production
LOG_LEVEL=info

# Timezone for cron jobs and scheduling
TZ=Europe/London

# OpenAI (text only — image generation has been removed)
OPENAI_API_KEY=sk-proj-replace-me
OPENAI_TEXT_MODEL=gpt-4.1
# Optional: override API base URL (rarely needed)
# OPENAI_BASE_URL=https://api.openai.com/v1

# Zernio (social media scheduling)
ZERNIO_API_KEY=sk_replace-me
ZERNIO_BASE_URL=https://zernio.com/api/v1

# Zernio account IDs (Strong Recruitment Group)
ZERNIO_ACCOUNT_FACEBOOK=69c00c826cb7b8cf4c8e23d9
ZERNIO_ACCOUNT_GOOGLE=69c014776cb7b8cf4c8e3f49
ZERNIO_ACCOUNT_INSTAGRAM=69c00b346cb7b8cf4c8e2090
ZERNIO_ACCOUNT_LINKEDIN=69c014136cb7b8cf4c8e3dd5
ZERNIO_ACCOUNT_TWITTER=69c0143b6cb7b8cf4c8e3e69

# Telegram
TELEGRAM_BOT_TOKEN=replace-me
TELEGRAM_CHAT_ID=replace-me

# Cron schedule (default: 09:00 on the 20th of every month, Europe/London)
CALENDAR_CRON="0 9 20 * *"

# Optional override: lookahead (months) for which calendar to generate when cron fires
# 1 = generate next month's calendar (default)
CALENDAR_LOOKAHEAD_MONTHS=1

# Storage
# Local directory used to store Telegram-uploaded images served at /images/*.
# On Railway this should be a mounted persistent volume (e.g. /app/data).
DATA_DIR=./data

# Supabase (replaces the previous SQLite store).
# Create a project at https://supabase.com and run the schema in /sql/schema.sql
# (or via the Supabase SQL editor). Use the SERVICE ROLE key — this app is
# server-side only.
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_KEY=eyJhbGciOi...replace-me

# Public base URL of this service (used so Zernio can fetch user-uploaded images)
# Set this to the Railway public URL, e.g.
#   https://strong-marketing-agent-production.up.railway.app
PUBLIC_BASE_URL=https://strong-marketing-agent-production.up.railway.app

# Optional: secret token required by manual trigger endpoints
TRIGGER_SECRET=change-me
