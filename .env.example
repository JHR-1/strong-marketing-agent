# ----------------------------------------------------------------------
# Strong / Zentra Marketing Agent — Environment variables
# ----------------------------------------------------------------------
# The agent now supports MULTIPLE companies (currently `strong` and
# `zentra`). Each company has its own Zernio profile + channel accounts.
# Existing single-company env vars (the original ZERNIO_ACCOUNT_* and
# ZERNIO_PROFILE_ID variables) keep working as the Strong fallback so
# Strong Recruitment deploys do not need any changes.
# ----------------------------------------------------------------------

# Server
PORT=3000
NODE_ENV=production
LOG_LEVEL=info

# Timezone for cron jobs and scheduling
TZ=Europe/London

# OpenAI (text only — image generation has been removed)
OPENAI_API_KEY=sk-proj-replace-me
OPENAI_TEXT_MODEL=gpt-4.1
# OPENAI_BASE_URL=https://api.openai.com/v1

# Zernio (social media scheduling)
ZERNIO_API_KEY=sk_replace-me
ZERNIO_BASE_URL=https://zernio.com/api/v1

# --- Strong Recruitment Group (existing) ------------------------------
# Either set the legacy variables (kept for backwards compatibility) ...
ZERNIO_PROFILE_ID=69c00b0b467c216082612e75
ZERNIO_ACCOUNT_FACEBOOK=69c00c826cb7b8cf4c8e23d9
ZERNIO_ACCOUNT_GOOGLE=69c014776cb7b8cf4c8e3f49
ZERNIO_ACCOUNT_INSTAGRAM=69c00b346cb7b8cf4c8e2090
ZERNIO_ACCOUNT_LINKEDIN=69c014136cb7b8cf4c8e3dd5
ZERNIO_ACCOUNT_TWITTER=69c0143b6cb7b8cf4c8e3e69
# ... or, equivalently, the new company-scoped variants:
# ZERNIO_STRONG_PROFILE_ID=69c00b0b467c216082612e75
# ZERNIO_STRONG_ACCOUNT_FACEBOOK=...
# ZERNIO_STRONG_ACCOUNT_INSTAGRAM=...
# ZERNIO_STRONG_ACCOUNT_LINKEDIN=...
# ZERNIO_STRONG_ACCOUNT_TWITTER=...
# ZERNIO_STRONG_ACCOUNT_GOOGLE=...

# --- Zentra Peptides (new) -------------------------------------------
# Zentra posts to Facebook, Instagram and Twitter/X only.
# The profile id is provided by Zernio for the Zentra workspace.
ZERNIO_ZENTRA_PROFILE_ID=6a0215e005cbe2cbf1a929d2
ZERNIO_ZENTRA_ACCOUNT_FACEBOOK=
ZERNIO_ZENTRA_ACCOUNT_INSTAGRAM=
ZERNIO_ZENTRA_ACCOUNT_TWITTER=

# Telegram
TELEGRAM_BOT_TOKEN=replace-me
TELEGRAM_CHAT_ID=replace-me

# Cron schedule (default: 09:00 on the 20th of every month, Europe/London)
# When this fires the agent will generate calendars for ALL configured
# companies and send each one to Telegram in turn.
CALENDAR_CRON="0 9 20 * *"

# Optional override: lookahead (months) for which calendar to generate when cron fires
CALENDAR_LOOKAHEAD_MONTHS=1

# Which company a fresh Telegram chat starts on (defaults to `strong`).
DEFAULT_COMPANY_SLUG=strong

# Storage
DATA_DIR=./data

# Supabase
# Run sql/migrations/0001_multi_company.sql once before deploying this
# version to add the `company` column to existing tables and backfill
# all existing rows to company='strong'.
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_KEY=eyJhbGciOi...replace-me

# Public base URL of this service (used so Zernio can fetch user-uploaded images)
PUBLIC_BASE_URL=https://strong-marketing-agent-production.up.railway.app

# Optional: secret token required by manual trigger endpoints
TRIGGER_SECRET=change-me
